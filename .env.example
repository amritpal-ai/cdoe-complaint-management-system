# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# ---- Flask ----
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string

# ---- Database ----
# Path is relative to the project root. The SQLite file lives in instance/.
DATABASE_URL=sqlite:///cdoe.db

# ---- Email (IMAP) — used starting Phase 6, not needed for Phase 0 ----
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=complaints@example.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# How often (minutes) APScheduler auto-syncs email. Also used starting Phase 6.
SYNC_INTERVAL_MINUTES=2
